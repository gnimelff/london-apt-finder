# Copy to .env and fill in your values.
# No database setup needed — the app uses a local SQLite file (seen.db).

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# TfL — register free at https://api-portal.tfl.gov.uk/
TFL_API_KEY=your_tfl_app_key

# EPC Register — register at https://epc.opendatacommunities.org/
# After registering, run: echo -n "your@email.com:your_api_key" | base64
EPC_API_KEY=base64_encoded_email_colon_apikey

# CallMeBot WhatsApp — see notifications/whatsapp.py for setup instructions
CALLMEBOT_API_KEY=your_callmebot_key
WHATSAPP_PHONE=447911123456   # no + or spaces

# Optional: minimum score to send a notification (default 7)
SCORE_THRESHOLD=7
